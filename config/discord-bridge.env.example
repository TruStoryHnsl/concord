# Discord bridge credentials template (INS-024 Wave 2).
#
# Copy this file to `config/discord-bridge.env` and fill in the real
# values BEFORE enabling the bridge through the concord-api admin UI.
# The real file is gitignored — never commit it.
#
#   cp config/discord-bridge.env.example config/discord-bridge.env
#   chmod 600 config/discord-bridge.env
#   $EDITOR config/discord-bridge.env
#
# File mode MUST be 0600 (owner read/write only). docker-compose
# loads it via `env_file:` into the mautrix-discord container ONLY;
# concord-api never reads it.
#
# ---------------------------------------------------------------------
# MAUTRIX_DISCORD_BOT_TOKEN (required)
# ---------------------------------------------------------------------
# A Discord bot token from https://discord.com/developers/applications.
# Create a new application → Bot tab → "Reset Token" → copy the value
# into the line below.
#
# Required bot intents (enable these on the same Bot tab):
#   * Server Members Intent
#   * Message Content Intent
#
# Without MESSAGE_CONTENT the bridge receives events but cannot read
# message bodies, which reduces the bridge to a state-only relay —
# everyone will see "bridged user sent a message" with no payload.
#
# The token looks like: <24chars-base64url>.<6chars>.<27plus-chars>
# Treat it as a credential equivalent to a homeserver admin token.
MAUTRIX_DISCORD_BOT_TOKEN=REPLACE_ME

# ---------------------------------------------------------------------
# MAUTRIX_DISCORD_APPLICATION_ID (required)
# ---------------------------------------------------------------------
# The integer "Application ID" on the same Discord developer page.
# Used by mautrix-discord to generate the OAuth2 invite URL that
# operators paste into each guild they want to bridge.
#
# NOT a secret (it is public on the Discord developer UI), but kept
# here next to the bot token so both values get rolled together.
MAUTRIX_DISCORD_APPLICATION_ID=REPLACE_ME
